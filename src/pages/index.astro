---
import Layout from "../layouts/Layout.astro";

const services = [
  {
    title: "שטיפה אנרגטית",
    icon: "♻️",
    desc: "ניקוי שדות האנרגיה מסביב לגוף. מומלץ לתחושת כבדות, עייפות כרונית או תחושת תקיעות.",
    price: "90 ₪",
    featured: false,
  },
  {
    title: "ניקוי עמוק",
    icon: "🌀",
    desc: "עבודה עמוקה על טראומות ישנות, חסמים שחוזרים על עצמם, ודפוסים שלא מרפים.",
    price: "150 ₪",
    featured: true,
  },
  {
    title: "ריפוי מרחוק",
    icon: "🔮",
    desc: "טיפול אנרגטי מלא מרחוק, ללא צורך בהגעה פיזית. שולחים זמן מפגש ועובדים.",
    price: "120 ₪",
    featured: false,
  },
];

const whatCards = [
  {
    icon: "⚡",
    title: "שחרור חסמים",
    desc: "ניקוי אנרגיות שליליות שנצברו לאורך זמן.",
  },
  {
    icon: "✨",
    title: "איזון שדות",
    desc: "החזרת האנרגיה לזרימה טבעית ומאוזנת.",
  },
  {
    icon: "🌿",
    title: "חיבור מחדש",
    desc: "חיבור לאנרגיית החיים ולמהות הפנימית שלך.",
  },
];

const steps = [
  {
    n: "1",
    title: "שיחת היכרות",
    desc: "30 דקות שיחה חינמית להבנת הצרכים שלך.",
  },
  {
    n: "2",
    title: "מפגש טיפול",
    desc: "60-90 דקות עבודה אנרגטית מעמיקה.",
  },
  {
    n: "3",
    title: "ליווי לאחר",
    desc: "מעקב ואינטגרציה של השינויים.",
  },
];

const testimonials = [
  {
    quote:
      "הגעתי עם תחושת כבדות שליוותה אותי שנים. אחרי מפגש אחד הרגשתי כאילו הורדתי עשרה קילו מהנשמה.",
    name: "שרה ל.",
    city: "תל אביב",
  },
  {
    quote:
      "הייתי סקפטית לחלוטין, אבל ההמלצה של חברה שכנעה אותי לנסות. מאז אני חוזרת כל חודש.",
    name: "מיכל ר.",
    city: "חיפה",
  },
  {
    quote:
      "העבודה מרחוק הפתיעה אותי. ממש הרגשתי את השינוי בזמן הטיפול. ממליצה בחום!",
    name: "דנה כ.",
    city: "ירושלים",
  },
];

const trustStats = [
  { number: "8+", label: "שנות ניסיון" },
  { number: "200+", label: "לקוחות מרוצים" },
  { number: "3", label: "שיטות עבודה" },
  { number: "100%", label: "מחויבות אישית" },
];

const faqs = [
  {
    q: "כמה זמן נמשך הטיפול?",
    a: "מפגש שטיפה אנרגטית נמשך בין 60 ל-90 דקות. שיחת ההיכרות חינמית ונמשכת כ-30 דקות.",
  },
  {
    q: "מה להביא למפגש?",
    a: "רק את עצמך. אין צורך בהכנה מיוחדת. מומלץ ללבוש בגדים נוחים.",
  },
  {
    q: "האם ניתן לבצע טיפול מרחוק?",
    a: "כן! הטיפול מרחוק יעיל לא פחות מטיפול פרונטלי. נקבע זמן ואני עובדת מהצד שלי בעוד אתם בבית.",
  },
  {
    q: "כמה מפגשים צריך?",
    a: "תלוי בצרכים. לעתים מפגש אחד מספיק, לעתים מומלצת סדרה קצרה. נחליט יחד אחרי שיחת ההיכרות.",
  },
  {
    q: "האם זה כואב?",
    a: "ממש לא. רוב האנשים חשים נינוחות עמוקה וחום עדין.",
  },
];
---

<Layout>
  <!-- ============ NAV ============ -->
  <header id="nav" class="nav" data-testid="site-nav">
    <div class="nav-inner">
      <a href="#home" class="logo" data-testid="nav-logo">✦ אלכסנדרה</a>

      <nav class="nav-links" data-testid="nav-links">
        <a href="#about">אודות</a>
        <a href="#services">שירותים</a>
        <a href="#how-it-works">תהליך</a>
        <a href="#testimonials">המלצות</a>
        <a href="#contact">צור קשר</a>
      </nav>

      <a href="#contact" class="btn btn-gold nav-cta" data-testid="nav-book">קבע פגישה</a>

      <button
        class="hamburger"
        id="hamburger"
        aria-label="פתח תפריט"
        aria-expanded="false"
        data-testid="nav-hamburger"
      >
        <span></span><span></span><span></span>
      </button>
    </div>

    <nav class="mobile-menu" id="mobile-menu" data-testid="mobile-menu">
      <a href="#about">אודות</a>
      <a href="#services">שירותים</a>
      <a href="#how-it-works">תהליך</a>
      <a href="#testimonials">המלצות</a>
      <a href="#contact">צור קשר</a>
      <a href="#contact" class="btn btn-gold">קבע פגישה</a>
    </nav>
  </header>

  <!-- ============ HERO ============ -->
  <section id="home" class="hero" data-testid="hero">
    <div class="hero-orbs" aria-hidden="true">
      <span class="orb orb-gold orb-1"></span>
      <span class="orb orb-teal orb-2"></span>
      <span class="orb orb-gold orb-3"></span>
      <span class="orb orb-teal orb-4"></span>
    </div>
    <div class="hero-content">
      <p class="eyebrow">✦ שטיפה אנרגטית ✦</p>
      <h1 class="hero-title">שחררי מה שמכביד עלייך</h1>
      <p class="hero-subhead">
        שטיפה אנרגטית עמוקה לניקוי שדות האנרגיה, שחרור חסמים, וחיבור מחדש למהות
        שלך.
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-gold">התחילי את המסע</a>
        <a href="#what" class="btn btn-ghost">גלי עוד</a>
      </div>
    </div>
    <a href="#philosophy" class="scroll-indicator" aria-label="גלול למטה">
      <span class="arrow"></span>
    </a>
  </section>

  <!-- ============ PHILOSOPHY ============ -->
  <section id="philosophy" class="philosophy" data-testid="philosophy">
    <div class="divider-line"></div>
    <blockquote class="philosophy-quote">
      "הגוף יודע לרפא את עצמו — לפעמים הוא פשוט צריך מישהו שיפנה את הדרך."
    </blockquote>
    <p class="philosophy-attr">— אלכסנדרה</p>
  </section>

  <!-- ============ WHAT IS ENERGETIC WASH ============ -->
  <section id="what" class="what" data-testid="what">
    <div class="container">
      <h2 class="section-heading center">מהי שטיפה אנרגטית?</h2>
      <p class="what-sub">שיטה עתיקה לניקוי שדות האנרגיה סביב הגוף</p>
      <div class="what-grid">
        {
          whatCards.map((c) => (
            <div class="what-item" data-testid="what-card">
              <div class="what-icon">{c.icon}</div>
              <h3>{c.title}</h3>
              <p>{c.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section id="about" class="about" data-testid="about">
    <div class="container about-grid">
      <div class="about-image">
        <img
          src="/alexandra.jpg"
          alt="אלכסנדרה — מרפאה אנרגטית"
          class="about-photo"
          loading="lazy"
        />
      </div>
      <div class="about-text">
        <h2 class="section-heading">קצת עליי</h2>
        <p>
          שמי אלכסנדרה, ומזה למעלה מ-8 שנים אני מלווה אנשים בתהליכי ריפוי אנרגטי
          עמוק. עבדתי עם מעל 200 אנשים, וכל מפגש מחדש מוכיח לי שהגוף והנשמה תמיד
          יודעים את הדרך — הם רק צריכים ליווי עדין.
        </p>
        <div class="about-badges">
          <span class="about-badge">8+ שנות ניסיון</span>
          <span class="about-badge">200+ לקוחות</span>
          <span class="about-badge">3 שיטות עבודה</span>
        </div>
        <a href="#contact" class="text-link">בואי נעבוד יחד ←</a>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section id="services" class="services" data-testid="services">
    <div class="container">
      <h2 class="section-heading center">בחרי את הדרך שלך</h2>
      <div class="services-grid">
        {
          services.map((s) => (
            <div
              class={`service-card${s.featured ? " featured" : ""}`}
              data-testid="service-card"
            >
              <div class="card-top-line" />
              <div class="service-icon">{s.icon}</div>
              <h3>{s.title}</h3>
              <p class="service-desc">{s.desc}</p>
              <p class="service-price">{s.price}</p>
              <a href="#contact" class="btn btn-outline">
                קבעי תור
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how-it-works" class="how" data-testid="how">
    <div class="container">
      <h2 class="section-heading center">איך זה עובד</h2>
      <div class="steps">
        <div class="steps-line" aria-hidden="true"></div>
        {
          steps.map((step) => (
            <div class="step" data-testid="step">
              <div class="step-circle">{step.n}</div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section id="testimonials" class="testimonials" data-testid="testimonials">
    <div class="container">
      <h2 class="section-heading center">מה הלקוחות אומרים</h2>
      <div class="testimonials-grid">
        {
          testimonials.map((t) => (
            <figure class="testimonial-card" data-testid="testimonial-card">
              <div class="stars" aria-label="5 כוכבים">⭐⭐⭐⭐⭐</div>
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                — {t.name}, {t.city}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ TRUST SIGNALS ============ -->
  <section class="trust" data-testid="trust">
    <div class="container trust-row">
      {
        trustStats.map((stat) => (
          <div class="trust-stat" data-testid="trust-stat">
            <span class="trust-number">{stat.number}</span>
            <span class="trust-label">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section id="faq" class="faq" data-testid="faq">
    <div class="container faq-container">
      <h2 class="section-heading center">שאלות נפוצות</h2>
      <div class="faq-list">
        {
          faqs.map((item) => (
            <div class="faq-item" data-testid="faq-item">
              <button class="faq-question" aria-expanded="false">
                <span>{item.q}</span>
                <span class="faq-toggle" aria-hidden="true">+</span>
              </button>
              <div class="faq-answer">
                <p>{item.a}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section id="contact" class="contact" data-testid="contact">
    <div class="container contact-container">
      <h2 class="contact-heading">מוכנה להתחיל?</h2>
      <p class="contact-subtext">קבעי שיחת היכרות חינמית ב-30 דקות</p>
      <form class="contact-form" action="#" method="post" data-testid="contact-form">
        <div class="form-row">
          <label>
            <span>שם מלא</span>
            <input type="text" name="name" required />
          </label>
          <label>
            <span>דוא"ל</span>
            <input type="email" name="email" required />
          </label>
        </div>
        <label>
          <span>טלפון (אופציונלי)</span>
          <input type="tel" name="phone" />
        </label>
        <label>
          <span>ספרי לי קצת...</span>
          <textarea name="message" rows="4"></textarea>
        </label>
        <button type="submit" class="btn btn-gold btn-full">שלחי הודעה ✦</button>
      </form>
      <p class="contact-alt">
        או צרי קשר ישירות דרך
        <a href="#" class="contact-social" aria-label="Instagram">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      </p>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="footer" data-testid="footer">
    <div class="container footer-inner">
      <a href="#home" class="logo footer-logo">✦ אלכסנדרה | שטיפה אנרגטית ✦</a>
      <nav class="footer-nav">
        <a href="#about">אודות</a>
        <a href="#services">שירותים</a>
        <a href="#contact">צור קשר</a>
      </nav>
      <div class="footer-divider" aria-hidden="true"></div>
      <p class="footer-copy">© 2025 כל הזכויות שמורות</p>
    </div>
  </footer>

  <script is:inline>
    // Nav scroll effect
    const nav = document.getElementById("nav");
    const onScroll = () => {
      if (window.scrollY > 40) nav.classList.add("scrolled");
      else nav.classList.remove("scrolled");
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Mobile menu
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobile-menu");
    hamburger.addEventListener("click", () => {
      const open = mobileMenu.classList.toggle("open");
      hamburger.classList.toggle("open", open);
      hamburger.setAttribute("aria-expanded", String(open));
    });
    mobileMenu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        mobileMenu.classList.remove("open");
        hamburger.classList.remove("open");
        hamburger.setAttribute("aria-expanded", "false");
      })
    );

    // FAQ accordion
    document.querySelectorAll(".faq-question").forEach((btn) => {
      btn.addEventListener("click", () => {
        const item = btn.closest(".faq-item");
        const isOpen = item.classList.contains("open");
        document.querySelectorAll(".faq-item.open").forEach((el) => {
          el.classList.remove("open");
          el.querySelector(".faq-question").setAttribute("aria-expanded", "false");
        });
        if (!isOpen) {
          item.classList.add("open");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });
  </script>

  <style is:global>
    :root {
      --navy: #0a0f1e;
      --gold: #c9a96e;
      --teal: #5ca8a0;
      --cream: #e8e0d0;
      --card: #111827;
      --ink: #e8e0d0;

      --f-display: "Heebo", "Segoe UI", system-ui, sans-serif;
      --f-head: "Heebo", "Segoe UI", system-ui, sans-serif;
      --f-body: "Heebo", "Segoe UI", system-ui, sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 80px;
    }

    html,
    body {
      direction: rtl;
      overflow-x: hidden;
      max-width: 100%;
    }

    body {
      font-family: var(--f-body);
      color: var(--ink);
      line-height: 1.7;
      background: var(--navy);
      text-align: right;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-heading {
      font-family: var(--f-head);
      font-weight: 700;
      font-size: 38px;
      color: var(--cream);
      line-height: 1.3;
    }
    .section-heading.center {
      text-align: center;
    }

    /* ---------- Buttons ---------- */
    .btn {
      display: inline-block;
      font-family: var(--f-head);
      font-weight: 600;
      letter-spacing: 0.04em;
      font-size: 15px;
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 999px;
      cursor: pointer;
      border: 1.5px solid transparent;
      transition: all 0.25s ease;
    }
    .btn-gold {
      background: var(--gold);
      color: #0a0f1e;
      border-color: var(--gold);
    }
    .btn-gold:hover {
      background: #d8bd87;
      border-color: #d8bd87;
      transform: translateY(-2px);
    }
    .btn-ghost {
      background: transparent;
      color: var(--cream);
      border-color: rgba(232, 224, 208, 0.45);
    }
    .btn-ghost:hover {
      background: rgba(232, 224, 208, 0.08);
      border-color: var(--cream);
    }
    .btn-outline {
      background: transparent;
      color: var(--gold);
      border-color: var(--gold);
    }
    .btn-outline:hover {
      background: var(--gold);
      color: #0a0f1e;
    }
    .btn-full {
      width: 100%;
      border: none;
    }

    /* ---------- NAV ---------- */
    .nav {
      position: fixed;
      inset-block-start: 0;
      inset-inline: 0;
      z-index: 100;
      background: transparent;
      transition: background 0.3s ease, box-shadow 0.3s ease;
    }
    .nav.scrolled {
      background: rgba(10, 15, 30, 0.92);
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.35);
    }
    .nav-inner {
      max-width: 1240px;
      margin: 0 auto;
      padding: 18px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--f-display);
      font-weight: 700;
      font-size: 26px;
      color: var(--gold);
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 30px;
    }
    .nav-links a {
      font-family: var(--f-head);
      font-weight: 500;
      letter-spacing: 0.02em;
      font-size: 16px;
      color: var(--cream);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .nav-links a:hover {
      color: var(--gold);
    }
    .nav-cta {
      padding: 10px 24px;
      font-size: 14px;
    }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
    }
    .hamburger span {
      width: 26px;
      height: 2px;
      background: var(--cream);
      transition: all 0.3s ease;
    }
    .hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .hamburger.open span:nth-child(2) {
      opacity: 0;
    }
    .hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
    .mobile-menu {
      display: none;
      flex-direction: column;
      gap: 18px;
      background: rgba(10, 15, 30, 0.97);
      padding: 24px;
      border-block-start: 1px solid rgba(232, 224, 208, 0.1);
    }
    .mobile-menu.open {
      display: flex;
    }
    .mobile-menu a {
      font-family: var(--f-head);
      font-weight: 500;
      letter-spacing: 0.02em;
      font-size: 16px;
      color: var(--cream);
      text-decoration: none;
    }
    .mobile-menu .btn {
      text-align: center;
    }

    /* ---------- HERO ---------- */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      background:
        radial-gradient(circle at 20% 30%, rgba(92, 168, 160, 0.12), transparent 45%),
        radial-gradient(circle at 80% 70%, rgba(201, 169, 110, 0.14), transparent 45%),
        radial-gradient(circle at 50% 50%, #141b30, var(--navy) 70%);
    }
    .hero-orbs {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
    }
