---
import "../styles/global.css";
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/400-italic.css";
import "@fontsource/cormorant-garamond/600.css";
import "@fontsource/cormorant-garamond/600-italic.css";
import "@fontsource/raleway/300.css";
import "@fontsource/raleway/600.css";
import "@fontsource/inter/400.css";

const services = [
  {
    title: "Energetic Wash",
    duration: "60 minutes",
    desc: "A full-body energy cleanse that lifts heavy, stagnant energy and restores your natural flow.",
  },
  {
    title: "Deep Clearing",
    duration: "90 minutes",
    desc: "For those carrying old wounds, trauma, or emotional blocks. A powerful, multi-layered clearing session.",
  },
  {
    title: "Distance Healing",
    duration: "45 minutes",
    desc: "Energy has no borders. Receive a complete clearing session from the comfort of your own home.",
  },
];

const steps = [
  {
    n: "1",
    title: "We Connect",
    desc: "Short consultation to understand your current state and intentions.",
  },
  {
    n: "2",
    title: "The Clearing",
    desc: "Alexandra guides the energy through your field, releasing blocks and restoring flow.",
  },
  {
    n: "3",
    title: "Integration",
    desc: "You receive guidance on how to anchor the shifts in your daily life.",
  },
];

const testimonials = [
  {
    quote:
      "After my session with Alexandra I felt lighter than I have in years. Something heavy I'd been carrying just... lifted.",
    name: "Maya R.",
    city: "Tel Aviv",
  },
  {
    quote:
      "I was skeptical, but the shift was undeniable. My sleep improved, my anxiety quieted. This work is real.",
    name: "Daniel K.",
    city: "Jerusalem",
  },
  {
    quote:
      "The distance healing was just as powerful as in-person. I cried, I laughed, I felt free. Truly transformative.",
    name: "Tamar S.",
    city: "Haifa",
  },
];

const faqs = [
  {
    q: "What is an energetic wash?",
    a: "An energetic wash is a healing practice that clears dense, stagnant, or discordant energy from your physical and subtle body. Think of it as a deep cleanse — like washing away dust that has settled over time.",
  },
  {
    q: "Do I need to believe in energy healing for it to work?",
    a: "Openness helps, but belief isn't required. The energy responds to your body's state, not your intellectual position. Many skeptics have experienced profound shifts.",
  },
  {
    q: "How long does a session take?",
    a: "Sessions range from 45 to 90 minutes depending on the service. The Energetic Wash is 60 minutes, Deep Clearing is 90, and Distance Healing is 45 minutes.",
  },
  {
    q: "Can I book a distance session from abroad?",
    a: "Yes. Distance sessions are available worldwide. All you need is a quiet space, 45 minutes, and a reliable internet connection for our pre-session consultation.",
  },
  {
    q: "How many sessions do I need?",
    a: "One session often creates a noticeable shift. For deeper or long-standing patterns, a series of 3-5 sessions is recommended. Alexandra will guide you based on your individual needs.",
  },
  {
    q: "How do I prepare for a session?",
    a: "Drink water, wear comfortable clothing, and set an intention. Avoid alcohol the day before. Come with an open heart.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Alexandra — energy cleansing & healing. Personalized clearing sessions for body, mind & spirit."
    />
    <title>Alexandra — Energy Cleansing & Healing</title>
  </head>
  <body>
    <!-- ============ NAV ============ -->
    <header id="nav" class="nav" data-testid="site-nav">
      <div class="nav-inner">
        <a href="#home" class="logo" data-testid="nav-logo">Alexandra</a>

        <nav class="nav-links" data-testid="nav-links">
          <a href="#home">Home</a>
          <a href="#about">About</a>
          <a href="#services">Services</a>
          <a href="#how-it-works">How It Works</a>
          <a href="#contact">Contact</a>
        </nav>

        <a href="#contact" class="btn btn-gold nav-cta" data-testid="nav-book">Book Now</a>

        <button
          class="hamburger"
          id="hamburger"
          aria-label="Toggle menu"
          aria-expanded="false"
          data-testid="nav-hamburger"
        >
          <span></span><span></span><span></span>
        </button>
      </div>

      <nav class="mobile-menu" id="mobile-menu" data-testid="mobile-menu">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#contact">Contact</a>
        <a href="#contact" class="btn btn-gold">Book Now</a>
      </nav>
    </header>

    <!-- ============ HERO ============ -->
    <section id="home" class="hero" data-testid="hero">
      <div class="hero-orbs" aria-hidden="true">
        <span class="orb orb-gold orb-1"></span>
        <span class="orb orb-teal orb-2"></span>
        <span class="orb orb-gold orb-3"></span>
        <span class="orb orb-teal orb-4"></span>
      </div>
      <div class="hero-content">
        <p class="eyebrow">Energy Cleansing &amp; Healing</p>
        <h1 class="hero-title">
          Restore Your Energy.<br />Reclaim Your Light.
        </h1>
        <p class="hero-subhead">
          Personalized clearing sessions for body, mind &amp; spirit.
        </p>
        <div class="hero-ctas">
          <a href="#contact" class="btn btn-gold">Book Your Session</a>
          <a href="#how-it-works" class="btn btn-ghost">How It Works</a>
        </div>
      </div>
      <a href="#philosophy" class="scroll-indicator" aria-label="Scroll down">
        <span class="arrow"></span>
      </a>
    </section>

    <!-- ============ PHILOSOPHY ============ -->
    <section id="philosophy" class="philosophy" data-testid="philosophy">
      <div class="divider-line"></div>
      <blockquote class="philosophy-quote">
        Everything is energy. When we clear the static, what's left is
        clarity — the truest version of yourself.
      </blockquote>
      <p class="philosophy-attr">— Alexandra</p>
    </section>

    <!-- ============ WHAT IS ENERGY CLEANSING ============ -->
    <section id="what" class="what" data-testid="what">
      <div class="container">
        <h2 class="section-heading">What Is Energy Cleansing?</h2>
        <div class="what-grid">
          <div class="what-item">
            <div class="what-icon">🕯</div>
            <h3>Clears Stagnant Energy</h3>
            <p>Release the dense, heavy energy that settles in your field over time.</p>
          </div>
          <div class="what-item">
            <div class="what-icon">✨</div>
            <h3>Restores Balance</h3>
            <p>Return your body, mind, and spirit to their natural state of flow.</p>
          </div>
          <div class="what-item">
            <div class="what-icon">🌿</div>
            <h3>Heals &amp; Renews</h3>
            <p>Create space for renewal, vitality, and a deeper sense of self.</p>
          </div>
        </div>
        <p class="what-text">
          Energy cleansing is a gentle yet powerful practice that works with
          your subtle body to dissolve blockages and discord. By clearing what
          no longer serves you, it allows your natural energy to move freely
          again — leaving you grounded, clear, and renewed.
        </p>
      </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section id="about" class="about" data-testid="about">
      <div class="container about-grid">
        <div class="about-image" aria-hidden="true">
          <span class="monogram">A</span>
        </div>
        <div class="about-text">
          <h2 class="section-heading">Meet Alexandra</h2>
          <p>
            Alexandra has been guiding people through energetic transformation
            for over 8 years. Trained in Reiki, Shamanic healing, and
            Bio-energetics, she brings a grounded, compassionate presence to
            every session. Her work is deeply personal — each clearing is
            tailored to where you are right now.
          </p>
          <ul class="credentials">
            <li>✓ Certified Reiki Master</li>
            <li>✓ Shamanic Practitioner</li>
            <li>✓ Bio-Energetics Specialist</li>
          </ul>
          <a href="#contact" class="text-link">Work With Me →</a>
        </div>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section id="services" class="services" data-testid="services">
      <div class="container">
        <h2 class="section-heading center">Choose Your Path</h2>
        <div class="services-grid">
          {
            services.map((s) => (
              <div class="service-card" data-testid="service-card">
                <div class="card-top-line" />
                <h3>{s.title}</h3>
                <p class="service-desc">{s.desc}</p>
                <p class="service-duration">{s.duration}</p>
                <a href="#contact" class="btn btn-outline">
                  Book This Session
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section id="how-it-works" class="how" data-testid="how">
      <div class="container">
        <h2 class="section-heading center">How a Session Works</h2>
        <div class="steps">
          <div class="steps-line" aria-hidden="true"></div>
          {
            steps.map((step) => (
              <div class="step" data-testid="step">
                <div class="step-circle">{step.n}</div>
                <h3>{step.title}</h3>
                <p>{step.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ TESTIMONIALS ============ -->
    <section id="testimonials" class="testimonials" data-testid="testimonials">
      <div class="container">
        <h2 class="section-heading center">What Clients Say</h2>
        <div class="testimonials-grid">
          {
            testimonials.map((t) => (
              <figure class="testimonial-card" data-testid="testimonial-card">
                <blockquote>{t.quote}</blockquote>
                <figcaption>
                  — {t.name}, {t.city}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ TRUST SIGNALS ============ -->
    <section class="trust" data-testid="trust">
      <div class="container trust-row">
        <div class="trust-stat">
          <span class="trust-number">8+ Years</span>
          <span class="trust-label">Practice</span>
        </div>
        <div class="trust-stat">
          <span class="trust-number">200+ Clients</span>
          <span class="trust-label">Transformed</span>
        </div>
        <div class="trust-stat">
          <span class="trust-number">3 Modalities</span>
          <span class="trust-label">Integrated</span>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section id="faq" class="faq" data-testid="faq">
      <div class="container faq-container">
        <h2 class="section-heading center">Frequently Asked Questions</h2>
        <div class="faq-list">
          {
            faqs.map((item) => (
              <div class="faq-item" data-testid="faq-item">
                <button class="faq-question" aria-expanded="false">
                  <span>{item.q}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </button>
                <div class="faq-answer">
                  <p>{item.a}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ CONTACT ============ -->
    <section id="contact" class="contact" data-testid="contact">
      <div class="container contact-container">
        <h2 class="contact-heading">Book Your Session</h2>
        <p class="contact-subtext">
          Ready to begin? Reach out and Alexandra will personally respond
          within 24 hours.
        </p>
        <form class="contact-form" action="#" method="post" data-testid="contact-form">
          <div class="form-row">
            <label>
              <span>Full Name</span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" required />
            </label>
          </div>
          <div class="form-row">
            <label>
              <span>Phone (optional)</span>
              <input type="tel" name="phone" />
            </label>
            <label>
              <span>Service</span>
              <select name="service">
                <option>Energetic Wash</option>
                <option>Deep Clearing</option>
                <option>Distance Healing</option>
              </select>
            </label>
          </div>
          <label>
            <span>Message</span>
            <textarea name="message" rows="4"></textarea>
          </label>
          <button type="submit" class="btn btn-gold btn-full">Send My Message</button>
        </form>
        <p class="contact-alt">
          Or reach me directly:
          <a href="mailto:hello@alexandra-energy.com">hello@alexandra-energy.com</a>
          | +972 50 000 0000
        </p>
        <p class="contact-note">Sessions available Sunday–Friday, 9:00–19:00 IST</p>
      </div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer class="footer" data-testid="footer">
      <div class="container footer-inner">
        <a href="#home" class="logo footer-logo">Alexandra</a>
        <p class="footer-tagline">Restoring clarity. One field at a time.</p>
        <nav class="footer-nav">
          <a href="#home">Home</a>
          <a href="#about">About</a>
          <a href="#services">Services</a>
          <a href="#contact">Contact</a>
        </nav>
        <a href="#" class="footer-social" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <div class="footer-divider" aria-hidden="true"></div>
        <p class="footer-copy">© 2025 Alexandra Energy Cleansing. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline>
      // Nav scroll effect
      const nav = document.getElementById("nav");
      const onScroll = () => {
        if (window.scrollY > 40) nav.classList.add("scrolled");
        else nav.classList.remove("scrolled");
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // Mobile menu
      const hamburger = document.getElementById("hamburger");
      const mobileMenu = document.getElementById("mobile-menu");
      hamburger.addEventListener("click", () => {
        const open = mobileMenu.classList.toggle("open");
        hamburger.classList.toggle("open", open);
        hamburger.setAttribute("aria-expanded", String(open));
      });
      mobileMenu.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          mobileMenu.classList.remove("open");
          hamburger.classList.remove("open");
          hamburger.setAttribute("aria-expanded", "false");
        })
      );

      // FAQ accordion
      document.querySelectorAll(".faq-question").forEach((btn) => {
        btn.addEventListener("click", () => {
          const item = btn.closest(".faq-item");
          const isOpen = item.classList.contains("open");
          document.querySelectorAll(".faq-item.open").forEach((el) => {
            el.classList.remove("open");
            el.querySelector(".faq-question").setAttribute("aria-expanded", "false");
          });
          if (!isOpen) {
            item.classList.add("open");
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });
    </script>

    <style>
      :root {
        --navy: #1a1f2e;
        --gold: #c9973a;
        --teal: #5ca8a0;
        --cream: #f9f5ee;
        --sage: #eff5f3;
        --ink: #2e2e2e;

        --f-display: "Cormorant Garamond", Georgia, serif;
        --f-head: "Raleway", system-ui, sans-serif;
        --f-body: "Inter", system-ui, sans-serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px;
      }

      html,
      body {
        overflow-x: hidden;
        max-width: 100%;
      }

      body {
        font-family: var(--f-body);
        color: var(--ink);
        line-height: 1.6;
        background: #fff;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .section-heading {
        font-family: var(--f-head);
        font-weight: 600;
        font-size: 38px;
        color: var(--navy);
        line-height: 1.2;
      }
      .section-heading.center {
        text-align: center;
      }

      /* ---------- Buttons ---------- */
      .btn {
        display: inline-block;
        font-family: var(--f-head);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 13px;
        text-decoration: none;
        padding: 14px 30px;
        border-radius: 999px;
        cursor: pointer;
        border: 1.5px solid transparent;
        transition: all 0.25s ease;
      }
      .btn-gold {
        background: var(--gold);
        color: #fff;
        border-color: var(--gold);
      }
      .btn-gold:hover {
        background: #b3852f;
        border-color: #b3852f;
        transform: translateY(-2px);
      }
      .btn-ghost {
        background: transparent;
        color: #fff;
        border-color: rgba(255, 255, 255, 0.6);
      }
      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: #fff;
      }
      .btn-outline {
        background: transparent;
        color: var(--gold);
        border-color: var(--gold);
      }
      .btn-outline:hover {
        background: var(--gold);
        color: #fff;
      }
      .btn-full {
        width: 100%;
        border: none;
      }

      /* ---------- NAV ---------- */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: transparent;
        transition: background 0.3s ease, box-shadow 0.3s ease;
      }
      .nav.scrolled {
        background: var(--navy);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.25);
      }
      .nav-inner {
        max-width: 1240px;
        margin: 0 auto;
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 600;
        font-size: 28px;
        color: var(--gold);
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        gap: 30px;
      }
      .nav-links a {
        font-family: var(--f-head);
        font-weight: 300;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 13px;
        color: #fff;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .nav-links a:hover {
        color: var(--gold);
      }
      .nav-cta {
        padding: 10px 24px;
      }
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
      }
      .hamburger span {
        width: 26px;
        height: 2px;
        background: #fff;
        transition: all 0.3s ease;
      }
      .hamburger.open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .hamburger.open span:nth-child(2) {
        opacity: 0;
      }
      .hamburger.open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
      .mobile-menu {
        display: none;
        flex-direction: column;
        gap: 18px;
        background: var(--navy);
        padding: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }
      .mobile-menu.open {
        display: flex;
      }
      .mobile-menu a {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 14px;
        color: #fff;
        text-decoration: none;
      }
      .mobile-menu .btn {
        text-align: center;
      }

      /* ---------- HERO ---------- */
      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
        background:
          radial-gradient(circle at 20% 30%, rgba(92, 168, 160, 0.1), transparent 45%),
          radial-gradient(circle at 80% 70%, rgba(201, 151, 58, 0.12), transparent 45%),
          radial-gradient(circle at 50% 50%, #232a3d, var(--navy) 70%);
      }
      .hero-orbs {
        position: absolute;
        inset: 0;
        z-index: 0;
      }
      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
      }
      .orb-gold {
        background: rgba(201, 151, 58, 0.08);
      }
      .orb-teal {
        background: rgba(92, 168, 160, 0.06);
      }
      .orb-1 {
        width: 420px;
        height: 420px;
        top: -80px;
        left: -60px;
        animation: drift 18s ease-in-out infinite;
      }
      .orb-2 {
        width: 360px;
        height: 360px;
        bottom: -100px;
        right: -40px;
        animation: drift 22s ease-in-out infinite reverse;
      }
      .orb-3 {
        width: 280px;
        height: 280px;
        top: 30%;
        right: 20%;
        animation: pulse 14s ease-in-out infinite;
      }
      .orb-4 {
        width: 320px;
        height: 320px;
        bottom: 15%;
        left: 12%;
        animation: pulse 16s ease-in-out infinite 2s;
      }
      @keyframes drift {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(40px, -30px); }
      }
      @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 0.8; }
        50% { transform: scale(1.15); opacity: 1; }
      }
      .hero-content {
        position: relative;
        z-index: 1;
        padding: 100px 24px 0;
        max-width: 900px;
      }
      .eyebrow {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.25em;
        font-size: 13px;
        color: var(--gold);
        margin-bottom: 24px;
      }
      .hero-title {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 600;
        font-size: 72px;
        line-height: 1.1;
        color: #fff;
        margin-bottom: 22px;
      }
      .hero-subhead {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 400;
        font-size: 22px;
        color: var(--cream);
        opacity: 0.85;
        margin-bottom: 40px;
      }
      .hero-ctas {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .scroll-indicator {
        position: absolute;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1;
      }
      .scroll-indicator .arrow {
        display: block;
        width: 14px;
        height: 14px;
        border-right: 2px solid rgba(255, 255, 255, 0.6);
        border-bottom: 2px solid rgba(255, 255, 255, 0.6);
        transform: rotate(45deg);
        animation: bounce 2s infinite;
      }
      @keyframes bounce {
        0%, 100% { transform: rotate(45deg) translate(0, 0); }
        50% { transform: rotate(45deg) translate(6px, 6px); }
      }

      /* ---------- PHILOSOPHY ---------- */
      .philosophy {
        background: var(--cream);
        text-align: center;
        padding: 90px 24px;
      }
      .divider-line {
        width: 60px;
        height: 1px;
        background: var(--gold);
        margin: 0 auto 36px;
      }
      .philosophy-quote {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 400;
        font-size: 30px;
        line-height: 1.4;
        color: var(--navy);
        max-width: 720px;
        margin: 0 auto 24px;
      }
      .philosophy-attr {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 13px;
        color: var(--gold);
      }

      /* ---------- WHAT ---------- */
      .what {
        background: #fff;
        padding: 90px 0;
        text-align: center;
      }
      .what .section-heading {
        margin-bottom: 50px;
      }
      .what-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 40px;
        margin-bottom: 44px;
      }
      .what-icon {
        font-size: 44px;
        margin-bottom: 16px;
      }
      .what-item h3 {
        font-family: var(--f-head);
        font-weight: 600;
        font-size: 20px;
        color: var(--navy);
        margin-bottom: 10px;
      }
      .what-item p {
        color: #555;
        font-size: 15px;
      }
      .what-text {
        max-width: 720px;
        margin: 0 auto;
        color: #555;
        font-size: 16px;
      }

      /* ---------- ABOUT ---------- */
      .about {
        background: var(--cream);
        padding: 90px 0;
      }
      .about-grid {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 64px;
        align-items: center;
      }
      .about-image {
        width: 400px;
        height: 500px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
          radial-gradient(circle at 30% 30%, rgba(92, 168, 160, 0.25), transparent 60%),
          linear-gradient(135deg, #2a3145, var(--navy));
        box-shadow: 0 20px 50px rgba(26, 31, 46, 0.25);
      }
      .monogram {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 600;
        font-size: 120px;
        color: var(--gold);
      }
      .about-text .section-heading {
        margin-bottom: 20px;
      }
      .about-text p {
        color: #555;
        margin-bottom: 24px;
        font-size: 16px;
      }
      .credentials {
        list-style: none;
        margin-bottom: 24px;
      }
      .credentials li {
        font-family: var(--f-head);
        font-weight: 300;
        color: var(--navy);
        margin-bottom: 8px;
        font-size: 15px;
      }
      .text-link {
        font-family: var(--f-head);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 13px;
        color: var(--gold);
        text-decoration: none;
      }
      .text-link:hover {
        text-decoration: underline;
      }

      /* ---------- SERVICES ---------- */
      .services {
        background: #fff;
        padding: 90px 0;
      }
      .services .section-heading {
        margin-bottom: 50px;
      }
      .services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }
      .service-card {
        position: relative;
        background: linear-gradient(180deg, rgba(249, 245, 238, 0.4), #fff);
        border: 1px solid rgba(201, 151, 58, 0.35);
        border-radius: 8px;
        padding: 40px 30px;
        text-align: center;
        overflow: hidden;
        transition: all 0.3s ease;
      }
      .card-top-line {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gold);
      }
      .service-card:hover {
        border-color: var(--gold);
        box-shadow: 0 16px 40px rgba(201, 151, 58, 0.18);
        transform: translateY(-4px);
      }
      .service-card h3 {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 600;
        font-size: 28px;
        color: var(--navy);
        margin-bottom: 16px;
      }
      .service-desc {
        color: #555;
        font-size: 15px;
        margin-bottom: 16px;
      }
      .service-duration {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 12px;
        color: var(--teal);
        margin-bottom: 24px;
      }

      /* ---------- HOW ---------- */
      .how {
        background: var(--sage);
        padding: 90px 0;
      }
      .how .section-heading {
        margin-bottom: 60px;
      }
      .steps {
        position: relative;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        text-align: center;
      }
      .steps-line {
        position: absolute;
        top: 32px;
        left: 16%;
        right: 16%;
        height: 1px;
        background: rgba(201, 151, 58, 0.4);
        z-index: 0;
      }
      .step {
        position: relative;
        z-index: 1;
      }
      .step-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: 2px solid var(--gold);
        background: var(--sage);
        color: var(--gold);
        font-family: var(--f-display);
        font-weight: 600;
        font-size: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
      }
      .step h3 {
        font-family: var(--f-head);
        font-weight: 600;
        font-size: 20px;
        color: var(--navy);
        margin-bottom: 10px;
      }
      .step p {
        color: #555;
        font-size: 15px;
        max-width: 280px;
        margin: 0 auto;
      }

      /* ---------- TESTIMONIALS ---------- */
      .testimonials {
        background: var(--cream);
        padding: 90px 0;
      }
      .testimonials .section-heading {
        margin-bottom: 50px;
      }
      .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }
      .testimonial-card {
        background: #fff;
        border-left: 3px solid var(--gold);
        border-radius: 4px;
        padding: 32px 28px;
        box-shadow: 0 8px 24px rgba(26, 31, 46, 0.06);
      }
      .testimonial-card blockquote {
        font-family: var(--f-display);
        font-style: italic;
        font-size: 20px;
        line-height: 1.5;
        color: var(--navy);
        margin-bottom: 18px;
      }
      .testimonial-card figcaption {
        font-family: var(--f-head);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 12px;
        color: var(--gold);
      }

      /* ---------- TRUST ---------- */
      .trust {
        background: #fff;
        padding: 70px 0;
      }
      .trust-row {
        display: flex;
        justify-content: center;
        gap: 80px;
        flex-wrap: wrap;
        text-align: center;
      }
      .trust-stat {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .trust-number {
        font-family: var(--f-display);
        font-weight: 600;
        font-size: 48px;
        color: var(--gold);
        line-height: 1;
      }
      .trust-label {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 12px;
        color: var(--navy);
      }

      /* ---------- FAQ ---------- */
      .faq {
        background: #fff;
        padding: 90px 0;
      }
      .faq-container {
        max-width: 820px;
      }
      .faq .section-heading {
        margin-bottom: 44px;
      }
      .faq-item {
        border-bottom: 1px solid rgba(46, 46, 46, 0.12);
      }
      .faq-question {
        width: 100%;
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        text-align: left;
        padding: 22px 0;
        font-family: var(--f-head);
        font-weight: 600;
        font-size: 18px;
        color: var(--navy);
      }
      .faq-toggle {
        font-size: 24px;
        color: var(--gold);
        flex-shrink: 0;
        transition: transform 0.3s ease;
        line-height: 1;
      }
      .faq-item.open .faq-toggle {
        transform: rotate(45deg);
      }
      .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.35s ease;
      }
      .faq-item.open .faq-answer {
        max-height: 320px;
      }
      .faq-answer p {
        padding: 0 0 22px;
        color: #555;
        font-size: 16px;
      }

      /* ---------- CONTACT ---------- */
      .contact {
        background: var(--navy);
        padding: 90px 0;
      }
      .contact-container {
        max-width: 720px;
        text-align: center;
      }
      .contact-heading {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 600;
        font-size: 48px;
        color: #fff;
        margin-bottom: 16px;
      }
      .contact-subtext {
        font-family: var(--f-head);
        font-weight: 300;
        color: var(--cream);
        opacity: 0.85;
        margin-bottom: 40px;
      }
      .contact-form {
        text-align: left;
        margin-bottom: 32px;
      }
      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
      }
      .contact-form label {
        display: block;
        margin-bottom: 20px;
      }
      .form-row label {
        margin-bottom: 0;
      }
      .contact-form span {
        display: block;
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 12px;
        color: var(--cream);
        opacity: 0.8;
        margin-bottom: 8px;
      }
      .contact-form input,
      .contact-form select,
      .contact-form textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 6px;
        padding: 13px 16px;
        color: #fff;
        font-family: var(--f-body);
        font-size: 15px;
        transition: border-color 0.2s ease;
      }
      .contact-form input:focus,
      .contact-form select:focus,
      .contact-form textarea:focus {
        outline: none;
        border-color: var(--gold);
      }
      .contact-form select option {
        color: var(--ink);
      }
      .contact-alt {
        color: var(--cream);
        font-size: 15px;
        margin-bottom: 8px;
      }
      .contact-alt a {
        color: var(--gold);
        text-decoration: none;
      }
      .contact-note {
        font-family: var(--f-head);
        font-weight: 300;
        font-size: 13px;
        color: rgba(249, 245, 238, 0.6);
      }

      /* ---------- FOOTER ---------- */
      .footer {
        background: var(--navy);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 56px 0 32px;
        text-align: center;
      }
      .footer-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
      }
      .footer-logo {
        font-size: 30px;
      }
      .footer-tagline {
        font-family: var(--f-display);
        font-style: italic;
        font-size: 18px;
        color: var(--cream);
        opacity: 0.8;
      }
      .footer-nav {
        display: flex;
        gap: 26px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-nav a {
        font-family: var(--f-head);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 12px;
        color: #fff;
        text-decoration: none;
        opacity: 0.8;
      }
      .footer-nav a:hover {
        color: var(--gold);
        opacity: 1;
      }
      .footer-social {
        color: var(--gold);
        display: inline-flex;
      }
      .footer-divider {
        width: 80px;
        height: 1px;
        background: rgba(255, 255, 255, 0.15);
        margin: 8px 0;
      }
      .footer-copy {
        font-size: 13px;
        color: rgba(249, 245, 238, 0.5);
      }

      /* ---------- RESPONSIVE ---------- */
      @media (max-width: 768px) {
        .nav-links,
        .nav-cta {
          display: none;
        }
        .hamburger {
          display: flex;
        }
        .hero-title {
          font-size: 48px;
        }
        .section-heading {
          font-size: 30px;
        }
        .what-grid,
        .services-grid,
        .steps,
        .testimonials-grid {
          grid-template-columns: 1fr;
        }
        .steps-line {
          display: none;
        }
        .about-grid {
          grid-template-columns: 1fr;
          gap: 36px;
        }
        .about-image {
          width: 100%;
          max-width: 320px;
          height: 320px;
          margin: 0 auto;
        }
        .container {
          padding-left: 1.25rem;
          padding-right: 1.25rem;
        }
        .trust-row {
          gap: 44px;
        }
        .form-row {
          grid-template-columns: 1fr;
          gap: 0;
          margin-bottom: 0;
        }
        .form-row label {
          margin-bottom: 20px;
        }
      }

      @media (max-width: 480px) {
        .hero-title {
          font-size: 40px;
        }
        .hero-subhead {
          font-size: 19px;
        }
        .contact-heading {
          font-size: 36px;
        }
        .trust-number {
          font-size: 38px;
        }
        .philosophy-quote {
          font-size: 24px;
        }
        .services-grid {
          grid-template-columns: 1fr;
        }
        .trust-row {
          flex-direction: column;
          gap: 2rem;
        }
      }
    </style>
  </body>
</html>
